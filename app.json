{
  "expo": {
    "name": "Sadhana",
    "slug": "sadhana",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1418"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sadhana.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Sadhana reads your sleep and recovery signals to set your daily baseline. Data stays on-device.",
        "NSHealthUpdateUsageDescription": "Sadhana can write optional mindfulness sessions. Data stays on-device."
      }
    },
    "android": {
      "package": "com.sadhana.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1418"
      }
    },
    "platforms": ["ios", "android", "web"]
  }
}
