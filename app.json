{
  "expo": {
    "name": "Sadhyo",
    "slug": "sadhana",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1418"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sankalpsthakur.sadhana",
      "entitlements": {
        "com.apple.developer.healthkit": true
      },
      "infoPlist": {
        "NSHealthShareUsageDescription": "Sadhana reads sleep duration, heart-rate variability, and resting heart rate from Health to personalize daily practice guidance on your device. Sadhana does not write to Health."
      }
    },
    "android": {
      "package": "com.sankalpsthakur.sadhana",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1418"
      }
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "plugins": [
      "expo-font",
      "expo-iap"
    ]
  }
}
