{
  "expo": {
    "name": "Inner Phases",
    "slug": "sadhana",
    "scheme": "sadhana",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1418"
    },
    "ios": {
      "supportsTablet": true,
      "appleTeamId": "ZBSZPCY34Y",
      "bundleIdentifier": "com.sankalpsthakur.sadhana",
      "entitlements": {
        "com.apple.developer.healthkit": true
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": true,
        "SECURE_ENVELOPE_ALGORITHM": "AES-256-GCM",
        "SECURE_ENVELOPE_VERSION": 1,
        "AppStoreProductIDSource": "App Store Connect canonical product identifiers for TestFlight StoreKit loading",
        "AppStoreProductIDs": [
          "com.sadhana.premium.annual",
          "com.sadhana.premium.monthly"
        ],
        "NSHealthShareUsageDescription": "Inner Phases reads sleep duration, heart-rate variability, and resting heart rate from Health to personalize daily practice guidance on your device. Inner Phases does not write to Health."
      }
    },
    "android": {
      "package": "com.sankalpsthakur.sadhana",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1418"
      }
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "plugins": [
      "expo-font",
      "expo-iap",
      "expo-secure-store"
    ]
  }
}
